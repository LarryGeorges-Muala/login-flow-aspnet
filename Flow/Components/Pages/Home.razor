@using System.Linq
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@page "/"
@inject HttpClient Http
@inject ProtectedSessionStorage ProtectedSessionStore
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Register</PageTitle>

<div class="section-container">
    <div class="log-links-group">
        <a href="/profile" class="component-log-button">Login</a>
    </div>
    <form method="post" @onsubmit="RegisterClient" @formname="register">
        <AntiforgeryToken />
        <div class="form-group">
            <h2>Register</h2>
            <hr />
            <div class="component-form-container">
                <label class="label" for="firstName">First name:</label><br>
                <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    placeholder=">"
                    @bind-Value="firstName" @bind-Value:event="oninput"
                    required><br>
            </div>

            <div class="component-form-container">
                <label class="label" for="last_name">Last name:</label><br>
                <input
                    type="text"
                    id="last_name"
                    name="last_name"
                    placeholder=">"
                    @bind-Value="lastName" @bind-Value:event="oninput"
                    required><br>
            </div>

            <div class="component-form-container">
                <label class="label" for="email">Email:</label><br>
                <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder=">"
                    @bind-Value="email" @bind-Value:event="oninput"
                    required><br>
            </div>

            <div class="component-form-container">
                <label class="label" for="password">Password:</label><br>
                <input
                    type='@(isPasswordVisible ? "text" : "password")'
                    id="password"
                    name="password"
                    minlength="8"
                    placeholder=">"
                    @bind-Value="password" @bind-Value:event="oninput"
                    required><br>
            </div>

            <div class="component-form-container">
                <label class="label" for="passwordConfirm">Confirm Password:</label><br>
                <input
                    type='@(isPasswordVisible ? "text" : "password")'
                    id="passwordConfirm"
                    name="passwordConfirm"
                    minlength="8"
                    placeholder=">"
                    @bind-Value="passwordConfirm" @bind-Value:event="oninput"
                    required><br>
                    @if (!string.IsNullOrWhiteSpace(password) && !string.IsNullOrWhiteSpace(passwordConfirm))
                    {
                        @if (password == passwordConfirm)
                        {
                    <span class="passwords-match-icons">✔</span>
                        } else {
                    <span class="passwords-match-icons">✘</span>
                        }
                    }
            </div>

            <div class="component-form-container">
                <input
                    type="checkbox"
                    @onclick="() => isPasswordVisible = !isPasswordVisible">
                    <span class="component-form-password-show">Show Password</span>
            </div>

            <div class="component-form-container">
                <input type="submit" value="Submit" class="component-submit-button">
            </div>

            @if (!string.IsNullOrWhiteSpace(password))
            {
            <div class="password-strength">
                <div id="message">
                    <h4>Password must contain the following:</h4>
                    <p class='@(password.Any(char.IsLower) ? "valid" : "invalid")'>A <b>lowercase</b> letter</p>
                    <p class='@(password.Any(char.IsUpper) ? "valid" : "invalid")'>A <b>capital (uppercase)</b> letter</p>
                    <p class='@(password.Any(char.IsDigit) ? "valid" : "invalid")'>A <b>number</b></p>
                    <p class='@(password?.Length >= 8 ? "valid" : "invalid")'>Minimum <b>8 characters</b></p>
                </div>
            </div>
            }
            @if (apiResponse != null)
            {
                <p>@apiResponse</p>
            }
        </div>
    </form>
</div>

@code {
    private string firstName = string.Empty;
    private string lastName = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private string passwordConfirm = string.Empty;
    private bool isPasswordVisible = false;
    private string? apiResponse;
    private bool? requestCompleted;

    protected override async Task OnInitializedAsync()
    {

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Read from session
                var isAuthenticated = await ProtectedSessionStore.GetAsync<string>("isAuthenticated");
                var authToken = isAuthenticated.Success ? isAuthenticated.Value : "";
                // Redirect to Profile if Authenticated
                if (isAuthenticated.Success) {
                    NavigationManager.NavigateTo("/profile");
                }
            }
            catch (Exception ex)
            {
                apiResponse = $"Error: {ex.Message}";
            }
        }
    }

    private async Task RegisterClient()
    {
        try
        {
            var newClient = new ClientDto { 
                Id = 0,
                UserName = email,
                Password = password,
                FirstName = firstName,
                LastName = lastName,
                Email = email,
                Enabled = true,
                Active = false,
                Token = "",
                QrCode = "",
                QrCodeUrl = "",
                CreatedDate = DateTime.Now,
                LastUpdated = DateTime.Now
            };
            HttpResponseMessage response = await Http.PostAsJsonAsync("api/ClientItems", newClient);
            response.EnsureSuccessStatusCode();
            var responseBody = await response.Content.ReadFromJsonAsync<ApiResponseDto>();
            apiResponse = responseBody?.Message;
            requestCompleted = responseBody?.Completed;
            if (requestCompleted == true)
            {
                // Set Login Session
                await ProtectedSessionStore.SetAsync("isAuthenticated", email);
                // Complete
                await Task.CompletedTask;
                // Redirect to MFA
                NavigationManager.NavigateTo("/mfa", replace: true, forceLoad: false);
            }
        }
        catch (Exception ex)
        {
            apiResponse = $"Error: {ex.Message}";
        }
    }

    private class ApiResponseDto
    {
        public string Message { get; set; } = string.Empty;
        public bool Completed { get; set; } = false;
    }

    private class ClientDto
    {
        public long Id { get; set; }
        public string? UserName { get; set; } = string.Empty;
        public string? Password { get; set; } = string.Empty;
        public string? FirstName { get; set; } = string.Empty;
        public string? LastName { get; set; } = string.Empty;
        public string? Email { get; set; } = string.Empty;
        public bool Enabled { get; set; } = true;
        public bool Active { get; set; } = false;
        public string? Token { get; set; } = string.Empty;
        public string? QrCode { get; set; } = string.Empty;
        public string? QrCodeUrl { get; set; } = string.Empty;
        public DateTime? CreatedDate { get; set; } = DateTime.Now;
        public DateTime? LastUpdated { get; set; } = DateTime.Now;
    }
}
